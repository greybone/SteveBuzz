# Bot token from Discord Developer Portal
DISCORD_BOT_TOKEN=your_bot_token_here

# Optional: only react in this guild (leave empty for all guilds)
GUILD_ID=

# Target user: prefer ID (exact), username is fallback (case-insensitive)
TARGET_USER_ID=123456789012345678
# TARGET_USERNAME=SteveBuzz

# Optional: only trigger when user joins THIS voice channel (leave empty for any voice channel)
TARGET_VOICE_CHANNEL_ID=

# Text channel where repeated messages will be sent (when user joins voice)
TARGET_CHANNEL_ID=987654321098765432

# Message to send (same message sent SEND_COUNT times)
MESSAGE_TEXT=Welcome back! This is a repeated greeting.

# How many times to send the message
SEND_COUNT=3

# Delay in milliseconds between each message
DELAY_MS=1500

# Cooldown in seconds: same user joining voice again within this window won't re-trigger
COOLDOWN_SECONDS=60
